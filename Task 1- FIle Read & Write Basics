# Part B — Read from file
print("=== Reading python_notes.txt ===")

lines = []
try:
    with open("python_notes.txt", "r", encoding="utf-8") as file:
        i = 1
        for line in file:
            clean_line = line.strip()
            print(str(i) + ". " + clean_line)
            lines.append(clean_line)
            i = i + 1
    
    print("\nTotal lines:", len(lines))
    
    # Search for keyword
    keyword = input("\nEnter keyword to search: ").lower()
    found = False
    j = 0
    while j < len(lines):
        if keyword in lines[j].lower():
            print("Match found:", lines[j])
            found = True
        j = j + 1
    
    if not found:
        print("No lines contain '" + keyword + "'. Try another keyword.")
        
except FileNotFoundError:
    print("Error: python_notes.txt not found!")
except Exception as e:
    print("Error reading file:", str(e))